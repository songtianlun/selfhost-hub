---
const { rating = 0 } = Astro.props;
const fullStars = Math.floor(rating);
const hasHalfStar = rating % 1 >= 0.5;
---
<div class="inline-flex items-center gap-1 rounded-full border border-amber-200/60 bg-amber-50/80 px-2 py-1 text-amber-600 dark:border-amber-400/20 dark:bg-amber-400/10" aria-label={`Rating ${rating} out of 5`}>
  {Array.from({ length: 5 }).map((_, index) => {
    const filled = index < fullStars;
    const half = index === fullStars && hasHalfStar;
    return <span class={filled || half ? 'text-amber-500' : 'text-muted-foreground/30'}>{half ? '★' : '★'}</span>;
  })}
  <span class="ml-1 text-xs font-semibold text-amber-700 dark:text-amber-300">{rating.toFixed(1)}</span>
</div>
