---
const adClient = 'ca-pub-7296634171837358';
const adSlot = '3744772454';
---
<section class="mt-8 overflow-hidden rounded-2xl border border-border/60 bg-background/70 p-3" aria-label="Advertisement">
  <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adClient}`} crossorigin="anonymous"></script>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client={adClient}
    data-ad-slot={adSlot}
    data-ad-format="auto"
    data-full-width-responsive="true"
  ></ins>
  <script is:inline>
    window.adsbygoogle = window.adsbygoogle || [];
    window.adsbygoogle.push({});
  </script>
</section>
