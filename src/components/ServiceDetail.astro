---
import Rating from './Rating.astro';
import ServiceCard from './ServiceCard.astro';
import { isGithubRepoUrl } from '../../lib/github-api';
import type { Service } from '../../lib/services';
const { service, similarServices = [], language = 'zh' } = Astro.props as { service: Service; similarServices?: Service[]; language?: 'zh' | 'en' };
const isEn = language === 'en';
const home = isEn ? '/en' : '/';
const githubInfo = service.githubInfo;
const repoInfo = githubInfo && !githubInfo.error ? githubInfo : undefined;
const formatDate = (dateString?: string) => {
  if (!dateString) return '';
  return new Date(dateString).toLocaleDateString(isEn ? 'en-US' : 'zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---
<div class="container py-10">
  <a href={home} class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-muted-foreground transition hover:text-foreground">← {isEn ? 'Back to all services' : '返回到所有服务'}</a>
  <article class="glass-card overflow-hidden rounded-3xl p-6 md:p-8">
    <div class="grid gap-8 md:grid-cols-[1fr_360px] md:items-start">
      <div>
        <div class="mb-4 flex flex-wrap items-center gap-4">
          <h1 class="gradient-title text-4xl font-black tracking-tight md:text-5xl">{service.name}</h1>
          {service.rating && <Rating rating={service.rating} />}
        </div>
        <p class="mb-6 text-xl leading-8 text-muted-foreground">{service.description}</p>
        <div class="mb-7 flex flex-wrap gap-2">
          <a href={`${home}?category=${encodeURIComponent(service.category)}`} class="chip border-primary/30 text-primary">{service.category}</a>
          {service.tags.map((tag) => <a href={`${home}?tags=${encodeURIComponent(tag)}`} class="chip">{tag}</a>)}
        </div>
        <div class="flex flex-wrap gap-3">
          {service.website && <a class="btn-primary" href={service.website} target="_blank" rel="noopener noreferrer">{isEn ? 'Visit Website' : '访问网站'}</a>}
          {service.repo && <a class="btn-secondary" href={service.repo} target="_blank" rel="noopener noreferrer">{isEn ? 'Source Code' : '源码仓库'}</a>}
        </div>
      </div>
      {service.image && <div class="overflow-hidden rounded-2xl border border-border bg-muted"><img src={service.image} alt={service.name} class="h-full w-full object-cover transition duration-500 hover:scale-105" /></div>}
    </div>
  </article>
  {service.repo && isGithubRepoUrl(service.repo) && (
    <section class="glass-card mt-8 rounded-2xl p-5">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
        <h2 class="text-lg font-bold">{isEn ? 'GitHub repository information' : 'GitHub 仓库信息'}</h2>
        {githubInfo?.fetchTime && <span class="text-xs text-muted-foreground">{isEn ? 'Fetched' : '获取时间'} · {formatDate(githubInfo.fetchTime)}</span>}
      </div>
      {repoInfo ? (
        <div class="space-y-4">
          <div class="flex flex-wrap gap-3">
            <span class="chip">★ {repoInfo.stars.toLocaleString()}</span>
            {repoInfo.latestVersion && <span class="chip">{isEn ? 'Latest' : '最新版本'}: {repoInfo.latestVersion}</span>}
            {repoInfo.lastUpdated && <span class="chip">{isEn ? 'Updated' : '最后更新'}: {formatDate(repoInfo.lastUpdated)}</span>}
          </div>
          {repoInfo.readme && (
            <details class="rounded-2xl border border-border/70 bg-background/70 p-4">
              <summary class="cursor-pointer text-sm font-semibold text-primary">README</summary>
              <pre class="mt-4 max-h-[32rem] overflow-auto whitespace-pre-wrap text-sm leading-6 text-muted-foreground">{repoInfo.readme}</pre>
            </details>
          )}
        </div>
      ) : (
        <p class="rounded-2xl bg-destructive/10 p-4 text-sm text-destructive">{githubInfo?.error || (isEn ? 'GitHub information is not available.' : 'GitHub 信息暂不可用。')}</p>
      )}
    </section>
  )}
  <section class="prose dark:prose-invert mt-10 max-w-none rounded-3xl border border-border/60 bg-background/70 p-6 md:p-8" set:html={service.content || ''}></section>
  {similarServices.length > 0 && (
    <section class="mt-14">
      <h2 class="mb-6 text-2xl font-bold">{isEn ? 'Discover more' : '发现更多'}</h2>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {similarServices.map((item) => <ServiceCard service={item} language={language} />)}
      </div>
    </section>
  )}
</div>
